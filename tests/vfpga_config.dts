/dts-v1/;

/ {
    #address-cells = <1>;
    #size-cells = <1>;

    /* Mock AXI-Lite register space */
    vfpga_reg@40000000 {
        compatible = "generic-uio";
        reg = <0x40000000 0x10000>;
        label = "/dev/vfpga_reg";
    };

    /* Mock FPGA device */
    fpga0: fpga@41000000 {
        compatible = "generic-uio";
        reg = <0x41000000 0x1000>;
        label = "/dev/fpga0";
    };

    /* Mock I2C controller */
    i2c1: i2c@e0004000 {
        compatible = "cdns,i2c-r1p10";
        reg = <0xe0004000 0x1000>;
        bus_id = <1>;
        label = "/dev/i2c-1";
    };
};
