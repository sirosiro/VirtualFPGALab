/dts-v1/;

/ {
    model = "VirtualFPGALab S01 C++ Showcase Board";
    compatible = "vfpga,showcase-s01";

    #address-cells = <1>;
    #size-cells = <1>;

    chosen {
        stdout-path = "/vfpga_uart@40000000";
    };

    /* 標準 UART: CLI用 */
    vfpga_uart@40000000 {
        compatible = "xlnx,xps-uartlite-1.00.a";
        reg = <0x40000000 0x1000>;
        label = "/dev/ttyUL0";
        port = <2000>; /* TCP Bridge Port */
    };

    /* 標準 AXI GPIO: LED表示用 */
    vfpga_gpio@41200000 {
        compatible = "xlnx,xps-gpio-1.00.a";
        reg = <0x41200000 0x1000>;
        label = "/dev/uio1";
        xlnx,is-dual = <0x0>;
        registers = "DATA @ 0x00, TRI @ 0x04";
    };

    /* 独自 IP: Pattern Engine (LFSR/Sequencer) */
    vfpga_custom@42000000 {
        compatible = "vfpga,custom-engine-1.0";
        reg = <0x42000000 0x1000>;
        label = "/dev/uio0";
        /* CTRL: [0]=RUN, [2:1]=MODE(0:SEQ, 1:BIN, 2:LFSR) */
        registers = "CTRL @ 0x00, SPEED @ 0x04, STATUS @ 0x08";
    };
};
